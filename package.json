{
  "name": "gridgen",
  "version": "0.0.0",
  "description": "Author and build opinionated recommendation grids for Astro and Jekyll.",
  "license": "MIT",
  "private": false,
  "packageManager": "bun@1.3.12",
  "type": "module",
  "bin": {
    "gridgen": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "minimatch": "^10.2.3"
  },
  "scripts": {
    "dev": "bun --filter @gridgen/web dev",
    "gridgen": "bun packages/cli/src/bin.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.tools.json && bun --filter @gridgen/web typecheck",
    "lint": "eslint . --max-warnings=0 --report-unused-disable-directives-severity error --no-cache",
    "lint:fix": "eslint . --fix --max-warnings=0 --report-unused-disable-directives-severity error --no-cache",
    "format": "prettier --check . --log-level warn",
    "format:write": "prettier --list-different --write .",
    "fix": "bun run lint:fix && bun run format:write",
    "deadcode": "knip",
    "test": "bun test tests/cli tests/core tests/io tests/server tests/web --reporter=dots --randomize --concurrent",
    "test:flake": "bun run scripts/check-flaky-tests.ts",
    "e2e": "bun run build && bun scripts/prepare-e2e.ts && playwright test",
    "coverage": "bun run test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "build": "bun --filter @gridgen/web build",
    "build:web": "bun --filter @gridgen/web build",
    "build:package": "bun scripts/build-package.ts",
    "package:pack": "bun run build:package && bun pm pack --destination tmp/package",
    "package:verify": "bun scripts/verify-package.ts",
    "audit": "bun audit",
    "secrets": "gitleaks detect --source . --redact --no-banner",
    "check": "bun run typecheck && bun run lint && bun run format && bun run deadcode && bun run test && bun run build",
    "check:release": "bun run check && bun run coverage && bun run audit && bun run secrets"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@gridgen/cli": "workspace:*",
    "@gridgen/core": "workspace:*",
    "@gridgen/io": "workspace:*",
    "@gridgen/server": "workspace:*",
    "@playwright/test": "^1.59.1",
    "@types/bun": "1.3.12",
    "@types/node": "^24.12.2",
    "eslint": "10.2.1",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-no-unsanitized": "4.1.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-sonarjs": "4.0.0",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.5.0",
    "knip": "6.4.1",
    "prettier": "3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.58.2"
  }
}
